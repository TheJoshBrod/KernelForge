ninja_required_version = 1.3
cxx = c++
nvcc = /usr/local/cuda/bin/nvcc

cflags = -DTORCH_EXTENSION_NAME=opt_kernel_3 -DTORCH_API_INCLUDE_EXTENSION_H -isystem /home/gins/jbrod_sarnav_ai_compilers/try_2/Ghost-in-the-Shell-GPU-Compiler/env/lib/python3.12/site-packages/torch/include -isystem /home/gins/jbrod_sarnav_ai_compilers/try_2/Ghost-in-the-Shell-GPU-Compiler/env/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /usr/local/include/python3.12 -fPIC -std=c++17
post_cflags = 
cuda_cflags = -DTORCH_EXTENSION_NAME=opt_kernel_3 -DTORCH_API_INCLUDE_EXTENSION_H -isystem /home/gins/jbrod_sarnav_ai_compilers/try_2/Ghost-in-the-Shell-GPU-Compiler/env/lib/python3.12/site-packages/torch/include -isystem /home/gins/jbrod_sarnav_ai_compilers/try_2/Ghost-in-the-Shell-GPU-Compiler/env/lib/python3.12/site-packages/torch/include/torch/csrc/api/include -isystem /usr/local/cuda/include -isystem /usr/local/include/python3.12 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 --compiler-options '-fPIC' -std=c++17
cuda_post_cflags = 
cuda_dlink_post_cflags = 
sycl_dlink_post_cflags = 
ldflags = -shared -L/home/gins/jbrod_sarnav_ai_compilers/try_2/Ghost-in-the-Shell-GPU-Compiler/env/lib/python3.12/site-packages/torch/lib -lc10 -lc10_cuda -ltorch_cpu -ltorch_cuda -ltorch -ltorch_python -L/usr/local/cuda/lib64 -lcudart

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





rule link
  command = $cxx $in $ldflags -o $out

build kernel-3.cuda.o: cuda_compile /home/gins/jbrod_sarnav_ai_compilers/try_2/Ghost-in-the-Shell-GPU-Compiler/benchmarks/run_benchmarks/optimized_compiled_kernels/torch_nn_functional_dropout/kernel-3.cu





build opt_kernel_3.so: link kernel-3.cuda.o

default opt_kernel_3.so

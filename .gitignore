#####################
# Generic gitignore #
#####################

# Test/Temp files
tmp
output

# Large Data Files
*.pt
*.parquet

# Compiled files
benchmarks/compiled/*



# Python
Python-3.12.5/*
*.pyc
__pycache__/
*.egg-info*
dist/
env/
venv/
venv3/
.venv/
.pytest_cache

# JavaScript
bundle.js
*node_modules*
files_for_autograder_io/
*/var/*

# Virtual Machines
.vagrant/

# Text editors and IDEs
*~
*.lock
*.swp
.vscode
.ropeproject/
.vscode/
.idea

# macOS system files
*.DS_Store

# Zone Identifiers
*Zone.Identifier

# Google Drive and Dropbox
Icon
.dropbox*

{
  "productName": "Kernel Forge",
  "version": "1.0.0",
  "identifier": "com.kernelforge.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../.jac/client/dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [
      "../main.jac",
      "../jac.toml",
      "../app",
      "../assets",
      "../components",
      "../context",
      "../styles.css",
      "../mascot.png",
      "../walkers",
      "../../src",
      "../../kernels/generated",
      "../../requirements.txt",
      "../../run_cast.py",
      "../../.venv",
      "binaries/jac-sidecar.sh",
      "binaries/jac-sidecar.bat"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/TheJoshBrod/CGinS/releases/latest/download/latest.json"
      ],
      "pubkey": "updater.pub",
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
